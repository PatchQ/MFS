//@version=6

indicator("HK 子行業熱力圖 v2", overlay=true, max_lines_count=500)

// ============================================================
// 設定
// ============================================================
iMaxStocks  = input.int(50, "股票數量", minval=10, maxval=500)
iShowTable  = input.bool(true, "顯示行業資金流向表")
iShowGauge  = input.bool(true, "顯示行業漲跌儀表")

