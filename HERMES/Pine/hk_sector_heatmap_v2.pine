    array.set(stockCodes, 90, "0066");  array.set(stockNames, 90, "港鐵公司");   array.set(stockSectors, 90, 9)
    array.set(stockCodes, 91, "0257");  array.set(stockNames, 91, "中外運");      array.set(stockSectors, 91, 9)
