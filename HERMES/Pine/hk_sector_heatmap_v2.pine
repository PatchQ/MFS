// ============================================================
// 函數定義
// ============================================================
matchWords(arr, txt) =>
    result = false
    for i = 0 to array.size(arr) - 1
        if array.get(arr, i) != "" and str.contains(txt, array.get(arr, i))
            result := true
            break
    result

toTVSym(code) =>
    str.replace_all(code, ".HK", "")

// ============================================================
// 股票列表
// ============================================================
