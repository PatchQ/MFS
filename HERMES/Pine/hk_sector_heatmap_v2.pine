    // 物業服務 100-109
    array.set(stockCodes, 95, "1879");  array.set(stockNames, 95, "仲量聯行");   array.set(stockSectors, 95, 10)
    array.set(stockCodes, 96, "6098");  array.set(stockNames, 96, "碧桂園服務"); array.set(stockSectors, 96, 10)
    array.set(stockCodes, 97, "3319");  array.set(stockNames, 97, "雅生活");      array.set(stockSectors, 97, 10)

if barstate.isfirst
    initStocks()

// ============================================================
// 全域數據存儲（每根柱都更新）
// ============================================================
var float[] stockClose    = array.new_float(500, na)
var float[] stockPrevClose = array.new_float(500, na)
var float[] stockPctChg  = array.new_float(500, 0.0)
var float[] stockVolume   = array.new_float(500, 0.0)
var bool[]   stockValid   = array.new_bool(500, false)

// 行業聚合
var int[] risingCount  = array.new_int(12, 0)
var int[] fallingCount = array.new_int(12, 0)
var int[] totalCount   = array.new_int(12, 0)
var float[] totalChange= array.new_float(12, 0.0)
var float[] totalVol   = array.new_float(12, 0.0)

// ============================================================
// 讀取所有股票數據（每根柱都執行，解決CW10003）
// ============================================================
for i = 0 to 11
    array.set(risingCount, i, 0)
    array.set(fallingCount, i, 0)
    array.set(totalCount, i, 0)
    array.set(totalChange, i, 0.0)
    array.set(totalVol, i, 0.0)

for i = 0 to STOCKS_COUNT - 1
    sym = toTVSym(array.get(stockCodes, i))
    
    if sym == "0000" or sym == ""
        continue
    
    [c, o, v, h, l] = request.security(sym, "D", [close, open, volume, high, low])
    
    prevClose = array.get(stockPrevClose, i)
    change = na(prevClose) ? 0.0 : c - prevClose
    pctChange = c > 0 and not na(prevClose) and prevClose != 0 ? (change / prevClose) * 100 : 0.0
    
    array.set(stockClose, i, c)
    array.set(stockPrevClose, i, c)
    array.set(stockPctChg, i, pctChange)
    array.set(stockVolume, i, v)
    
    if not na(c) and c > 0
        array.set(stockValid, i, true)
        
        secIdx = array.get(stockSectors, i)
        array.set(totalCount, secIdx, array.get(totalCount, secIdx) + 1)
        array.set(totalChange, secIdx, array.get(totalChange, secIdx) + pctChange)
        array.set(totalVol, secIdx, array.get(totalVol, secIdx) + v)
        
        if pctChange > 0
            array.set(risingCount, secIdx, array.get(risingCount, secIdx) + 1)
        else if pctChange < 0
            array.set(fallingCount, secIdx, array.get(fallingCount, secIdx) + 1)
    else
        array.set(stockValid, i, false)

// ============================================================
// 顏色函數
// ============================================================
getSectorColor(idx) =>
    array.get(SECTOR_COLORS, idx)

// ============================================================
// 表格顯示（黑色背景）
// ============================================================
if barstate.islast and iShowTable
    var table heatTable = table.new(
        position.top_right, 
        5, 14, 
        bgcolor=color.black,
        border_width=1,
        border_color=color.new(color.white, 20)
    )
    
    // 表頭
    table.cell(heatTable, 0, 0, "子行業", 
        text_color=color.white, text_size=size.small,
        bgcolor=color.new(#0D47A1, 0))
    table.cell(heatTable, 1, 0, "↑ 升", 
        text_color=#00E676, text_size=size.small,
        bgcolor=color.new(#00C853, 0))
    table.cell(heatTable, 2, 0, "↓ 跌", 
        text_color=#FF5252, text_size=size.small,
        bgcolor=color.new(#FF1744, 0))
    table.cell(heatTable, 3, 0, "淨升跌", 
        text_color=color.white, text_size=size.small,
        bgcolor=color.new(#7B1FA2, 0))
    table.cell(heatTable, 4, 0, "板塊%", 
        text_color=color.white, text_size=size.small,
        bgcolor=color.new(#1565C0, 0))
    
    // 數據行
    for i = 0 to 11
        total = array.get(totalCount, i)
        rising = array.get(risingCount, i)
        falling = array.get(fallingCount, i)
        
        if total > 0
            ratio = rising / total
            netChange = rising - falling
            avgChange = array.get(totalChange, i) / total
            secCol = getSectorColor(i)
            
            bgCol = ratio > 0.6 ? color.new(#00C853, 0) : ratio < 0.4 ? color.new(#FF1744, 0) : color.new(#78909C, 0)
            
            table.cell(heatTable, 0, i+1, array.get(SECTOR_NAMES, i), 
                text_color=color.white, text_size=size.small, bgcolor=bgCol)
            table.cell(heatTable, 1, i+1, str.tostring(rising), 
                text_color=#00E676, text_size=size.small, bgcolor=bgCol)
            table.cell(heatTable, 2, i+1, str.tostring(falling), 
                text_color=#FF5252, text_size=size.small, bgcolor=bgCol)
            table.cell(heatTable, 3, i+1, (netChange > 0 ? "+" : "") + str.tostring(netChange), 
                text_color=netChange > 0 ? #00E676 : #FF5252, text_size=size.small, bgcolor=bgCol)
            table.cell(heatTable, 4, i+1, (avgChange > 0 ? "▲" : avgChange < 0 ? "▼" : "─") + str.tostring(math.round(avgChange, 2)) + "%", 
                text_color=avgChange > 0 ? #00E676 : #FF5252, text_size=size.small, bgcolor=bgCol)

// ============================================================
// 行業指數儀表盤（黑色背景）
// ============================================================
if barstate.islast and iShowGauge
    var table gaugeTable = table.new(position.top_left, 4, 5, bgcolor=color.black)
    
    table.cell(gaugeTable, 0, 0, "熱力圖", text_color=color.white, text_size=size.small, bgcolor=color.new(#0D47A1, 0))
    table.cell(gaugeTable, 1, 0, "升", text_color=#00E676, text_size=size.small, bgcolor=color.new(#00C853, 0))
    table.cell(gaugeTable, 2, 0, "跌", text_color=#FF5252, text_size=size.small, bgcolor=color.new(#FF1744, 0))
    table.cell(gaugeTable, 3, 0, "方向", text_color=color.white, text_size=size.small, bgcolor=color.new(#7B1FA2, 0))
    
    totalRising = array.sum(risingCount)
    totalFalling = array.sum(fallingCount)
    totalStocks = array.sum(totalCount)
    overallRatio = totalStocks > 0 ? totalRising / totalStocks : 0.5
    
    overallCol = overallRatio > 0.55 ? color.new(#00C853, 0) : overallRatio < 0.45 ? color.new(#FF1744, 0) : color.new(#78909C, 0)
    
    table.cell(gaugeTable, 0, 1, "全市場", text_color=color.white, text_size=size.small, bgcolor=overallCol)
    table.cell(gaugeTable, 1, 1, str.tostring(totalRising), text_color=#00E676, text_size=size.small, bgcolor=overallCol)
    table.cell(gaugeTable, 2, 1, str.tostring(totalFalling), text_color=#FF5252, text_size=size.small, bgcolor=overallCol)
    table.cell(gaugeTable, 3, 1, overallRatio > 0.5 ? "▲ 多頭" : "▼ 空頭", 
        text_color=overallRatio > 0.5 ? #00E676 : #FF5252, text_size=size.small, bgcolor=overallCol)

// ============================================================
// 繪製板塊標籤
// ============================================================
if barstate.islast and iShowGauge
    var float maxAvg = -999.0
    var float minAvg = 999.0
    var int maxIdx = 0
    var int minIdx = 0
    
    for i = 0 to 11
        total = array.get(totalCount, i)
        if total > 0
            avg = array.get(totalChange, i) / total
            if avg > maxAvg
                maxAvg := avg
                maxIdx := i
            if avg < minAvg
                minAvg := avg
                minIdx := i
    
    if maxAvg > 0
        label.new(bar_index - 5, high, "🚀 " + array.get(SECTOR_NAMES, maxIdx) + " ▲" + str.tostring(math.round(maxAvg, 1)) + "%", color=color.new(#00C853, 70), textcolor=color.white, size=size.small, style=label.style_label_down)
    if minAvg < 0
        label.new(bar_index - 5, low, "💎 " + array.get(SECTOR_NAMES, minIdx) + " ▼" + str.tostring(math.round(math.abs(minAvg), 1)) + "%", color=color.new(#FF1744, 70), textcolor=color.white, size=size.small, style=label.style_label_up)
